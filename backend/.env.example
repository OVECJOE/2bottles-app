PORT=8080
CORS_ORIGIN=*
JWT_SECRET=replace-me-in-production
AUTH_REQUIRED=false
WS_CHAT_RATE_LIMIT_COUNT=12
WS_CHAT_RATE_LIMIT_WINDOW_MS=10000
WS_LOCATION_RATE_LIMIT_COUNT=20
WS_LOCATION_RATE_LIMIT_WINDOW_MS=10000
WS_MAX_CHAT_MESSAGE_LENGTH=500
WS_MAX_EVENT_AGE_MS=300000
WS_MAX_FUTURE_SKEW_MS=60000
API_MAX_NAME_LENGTH=80
API_MAX_EXTERNAL_ID_LENGTH=128
API_MAX_HISTORY_LIMIT=500
AUDIT_LOG_ENABLED=true
AUDIT_LOG_LEVEL=info
AUDIT_LOG_SINK=console
# Set to your managed Postgres URL when DB wiring is added.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/2bottles
# Optional: enable cross-instance WebSocket fanout.
# REDIS_URL=redis://localhost:6379
# REDIS_CHANNEL=2bottles:realtime
# REDIS_INVITE_CHANNEL=2bottles:invites
# INSTANCE_ID=backend-1
# Optional: shared rate-limit key prefix when Redis is enabled.
# WS_RATE_LIMIT_PREFIX=2bottles:ws:rate
# Optional: cooldown after Redis limiter failures before retrying Redis.
# WS_RATE_LIMIT_REDIS_DEGRADED_MS=30000
# Optional: distributed presence heartbeat and stale cutoff.
# WS_REMOTE_PRESENCE_HEARTBEAT_MS=10000
# WS_REMOTE_PRESENCE_TTL_MS=30000

# Optional: Web Push (invite notifications)
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:ops@example.com

# Optional: Stripe payments
# STRIPE_SECRET_KEY=sk_live_or_test
# STRIPE_PRICE_ID_PAID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...
